# Copy to .env and fill in. See SECURITY.md for the production checklist.

# --- App ---
APP_NAME=Lambda API
# Leave false in production: true exposes stack traces and SQL query logs.
DEBUG=false

# --- Database ---
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/lambda

# --- Admin endpoints (X-Admin-Key) ---
# Long random value. Generate: python -c "import secrets; print(secrets.token_urlsafe(32))"
# If empty, admin routes return 503 (disabled).
ADMIN_API_KEY=

# --- Auth (only relevant if user accounts are re-enabled) ---
# Long random value. Generate: python -c "import secrets; print(secrets.token_urlsafe(32))"
JWT_SECRET=
# DEV ONLY. Short-circuits JWT auth and returns this user id. MUST be empty in production.
AUTH_BYPASS_USER_ID=

# --- CORS ---
# Comma/JSON list of allowed frontend origins. Default is localhost-only;
# set your real frontend origin(s) in production. Do not use "*" with credentials.
# CORS_ORIGINS=["https://your-frontend.example.com"]

# --- Rate limiting ---
RATE_LIMIT_DEFAULT=60/minute
RATE_LIMIT_SUBMIT=5/minute
RATE_LIMIT_SUBMIT_GLOBAL=200/hour
# true behind a proxy/load balancer (e.g. Railway); false if exposed directly.
TRUST_FORWARDED_FOR=true
# Empty = in-memory (single instance only). For multiple instances, use Redis:
# RATE_LIMIT_STORAGE_URI=redis://default:password@host:6379
RATE_LIMIT_STORAGE_URI=

# --- Analytics (PostHog) ---
# Project API key. Empty = analytics disabled (no client, no events). Find it in
# PostHog under Settings > Project > Project API Key.
POSTHOG_API_KEY=
# Ingestion host. US Cloud by default; use https://eu.i.posthog.com for EU Cloud
# or your own URL when self-hosting.
POSTHOG_HOST=https://us.i.posthog.com
